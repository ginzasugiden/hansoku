# HANASABI 環境変数テンプレート
# このファイルをコピーして .env を作成（.envはgitignore済み）
# GASにはこのファイルではなくPropertiesServiceに直接設定してください

# ── 楽天 ──────────────────────────────────────
RAKUTEN_SERVICE_SECRET=ここにサービスシークレット
RAKUTEN_LICENSE_KEY=ここにライセンスキー
RAKUTEN_SHOP_URL=normal.shop.rakuten.co.jp

# ── AI ────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# ── LINE ──────────────────────────────────────
LINE_CHANNEL_SECRET=ここにChannelSecret（32文字）
LINE_CHANNEL_ACCESS_TOKEN=ここにLong-livedToken

# ── 内部認証 ──────────────────────────────────
# setupProperties()実行後にGASコンソールでAPP_BEARER_TOKENを確認
APP_BEARER_TOKEN=（自動生成されたトークン）

# ── Google Sheets ─────────────────────────────
SHEET_ID=ここにスプレッドシートのID（URLの/d/以降）

# ── フロントエンド ────────────────────────────
# GitHub PagesのURL（GAS CORSの許可オリジン）
FRONTEND_ORIGIN=https://ginzasugiden.github.io
GAS_WEB_APP_URL=https://script.google.com/macros/s/（デプロイID）/exec
